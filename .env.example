# PatronAI — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs

# Base de données Postgres (Supabase)
# DATABASE_URL = connection string avec PgBouncer (pooled, port 6543)
# DIRECT_URL   = connection string directe (pour migrations, port 5432)
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Anthropic — Clé API pour Claude Vision
ANTHROPIC_API_KEY="sk-ant-..."

# Clerk — Authentification
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/generate"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/generate"

# Stripe — Paiement (requis en V2, laisser vide en V1)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# URL publique de l'app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
